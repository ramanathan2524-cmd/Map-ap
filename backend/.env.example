# ─────────────────────────────────────────────────────────────────────────────
# AP Election Map — Backend Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000
LOG_LEVEL=info
LOG_QUERIES=false

# PostgreSQL + PostGIS
DATABASE_URL="postgresql://postgres:password@localhost:5432/ap_election_map?schema=public"

# Redis (optional — caching)
REDIS_URL="redis://localhost:6379"

# CORS — comma-separated list of allowed origins
CORS_ORIGIN="http://localhost:3000"

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
