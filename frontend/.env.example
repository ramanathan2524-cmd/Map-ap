# ─────────────────────────────────────────────────────────────────────────────
# AP Election Map — Frontend Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# API base URL (leave as /api/v1 to use Vite's dev proxy)
VITE_API_URL=/api/v1

# Mapbox token (only needed if you switch from Leaflet to Mapbox GL JS)
# VITE_MAPBOX_TOKEN=pk.eyJ1...

# Feature flags
VITE_ENABLE_BOOTH_CLUSTERING=true
VITE_MAX_BOOTH_MARKERS=1000
